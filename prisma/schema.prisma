generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  isDeleted    Boolean  @default(false)

  ownedBoards  Board[]       @relation("BoardOwner")
  memberships  BoardMember[]

  assignedTasks Task[] @relation("TaskAssignee")
  createdTasks  Task[] @relation("TaskCreator")

  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]

  ownedOrgs      Organization[] @relation("OrgOwner")
  orgMemberships OrgMember[]
}

model Board {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  ownerId   Int
  owner     User     @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  orgId     Int?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  members   BoardMember[]

  columns   BoardColumn[]
  tasks     Task[]

  @@index([ownerId])
  @@index([orgId])
}

model BoardMember {
  boardId  Int
  userId   Int
  role     BoardRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  board    Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boardId, userId])
  @@index([userId])
}

model BoardColumn {
  id        Int      @id @default(autoincrement())
  boardId   Int
  name      String
  position  Int    

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([boardId, name])
  @@index([boardId, position])
}

model Task {
  id          Int      @id @default(autoincrement())

  boardId     Int
  columnId    Int

  title       String
  description String?

  position    Int    
  priority    Int      @default(0)

  assigneeId  Int?
  dueDate     DateTime?

  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board       Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column      BoardColumn @relation(fields: [columnId], references: [id], onDelete: Restrict)

  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   User        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([boardId])
  @@index([columnId, position])
  @@index([assigneeId])
  @@index([dueDate])
}

enum BoardRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  ownerId   Int
  owner     User      @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members   OrgMember[]
  boards    Board[]

  @@index([ownerId])
}

model OrgMember {
  orgId    Int
  userId   Int
  role     OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@index([userId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id        Int       @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String?
  entityId  Int?
  details   String?
  createdAt DateTime  @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}
